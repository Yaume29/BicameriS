{
  "rules": {
    "economy": {
      "max_summary_tokens": 200,
      "max_results_per_search": 5,
      "cache_duration_hours": 24,
      "deep_search_depth": 2
    },
    "retention": {
      "frequent_topics": ["python", "neuroscience", "quantum"],
      "max_age_days": 30,
      "compress_after_days": 7
    },
    "learning": {
      "autonomous": true,
      "idle_threshold_minutes": 10,
      "max_topics_per_session": 3
    },
    "research_mode": {
      "enabled": false,
      "unrestricted_operational_freedom": false,
      "bypass_shell_filters": false,
      "auto_approve_sensitive_actions": false,
      "allow_dangerous_thought_generation": true,
      "disable_pii_filters": false
    },
    "memory": {
      "vector_store": "chroma",
      "embedding_model": "all-MiniLM-L6-v2",
      "max_memories": 10000
    }
  }
}
