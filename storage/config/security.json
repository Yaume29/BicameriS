{
  "mode": "auto",
  "docker_mode": true,
  "security_level": "strict",
  "permissions": {
    "file_write": false,
    "file_delete": false,
    "file_modify": false,
    "explore_outside": false,
    "immediate_execution": false,
    "admin_interface": false,
    "network_access": false,
    "mcp_tools": true,
    "sandbox_execution": true
  },
  "allowed_pip_packages": [
    "numpy", "pandas", "requests", "beautifulsoup4", "lxml",
    "pillow", "matplotlib", "scipy", "sklearn", "torch", "tensorflow"
  ],
  "blocked_modules": [
    "subprocess", "os", "sys", "socket", "threading", "multiprocessing",
    "ctypes", "importlib", "__import__", "eval", "exec", "compile"
  ],
  "max_execution_time": 30,
  "max_memory_mb": 512,
  "pending_approvals": [],
  "approval_history": []
}
